# ── Talaria UI — configuration ───────────────────────────────────────────────
# Copy to .env and fill in.

# The Talaria gateway plane (fleet multiplexer): /v1/models + model-routed chat.
# The UI's server routes proxy here (auth-gated), so the fleet URLs/keys never
# reach the browser. Unset ⇒ the chat runs in offline "mock" mode.
TALARIA_GATEWAY_URL=http://127.0.0.1:8642

# ── State ────────────────────────────────────────────────────────────────────
# Postgres — durable state (users, roles, per-agent access, conversations,
# messages). Redis — sessions + ephemeral state.
DATABASE_URL=postgres://talaria:talaria@127.0.0.1:5544/talaria
REDIS_URL=redis://127.0.0.1:6399

# ── Auth ─────────────────────────────────────────────────────────────────────
# Every provider is independently enable-able: a provider only appears on the
# login screen when its flag is on AND its required secrets are present.

# Admins (comma-separated emails). Everyone else who signs in (and passes the
# AUTH_ALLOWED_* gates) becomes a member.
AUTH_ADMIN_EMAILS=jon@packledger.co

# Optional — signs the OAuth state cookie (sessions are Redis-backed, so this is
# no longer required). Generate with: openssl rand -base64 48
AUTH_SECRET=

# Optional — external origin used to build OAuth redirect URIs. Leave blank to
# derive from the request (honours X-Forwarded-Proto/Host behind a proxy).
# AUTH_PUBLIC_URL=https://talaria.packledger.co

# Optional global allow-list (applies to every provider). Leave both blank to
# allow anyone who authenticates.
# AUTH_ALLOWED_DOMAINS=getboxie.com,packledger.co
# AUTH_ALLOWED_EMAILS=jon@getboxie.com

# ── Provider: Google OAuth ────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  <origin>/api/auth/google/callback
AUTH_GOOGLE_ENABLED=1
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# Optional — restrict to a Google Workspace domain.
# AUTH_GOOGLE_HD=getboxie.com

# ── Provider: Username / password ─────────────────────────────────────────────
# MVP stores users as "user:pass" pairs (comma-separated). Plaintext for now —
# hashing (bcrypt/argon2) is on the TODO list. Disable by leaving this off.
# AUTH_PASSWORD_ENABLED=1
# AUTH_USERS=jon@getboxie.com:change-me,ops:another-pass
