# ── Talaria UI — auth configuration ──────────────────────────────────────────
# Copy to .env and fill in. Every provider is independently enable-able: a
# provider only appears on the login screen when its flag is on AND its required
# secrets are present.

# REQUIRED — signing key for session + OAuth-state cookies. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET=

# Optional — external origin used to build OAuth redirect URIs. Leave blank to
# derive from the request (honours X-Forwarded-Proto/Host behind a proxy).
# AUTH_PUBLIC_URL=https://talaria.packledger.co

# Optional global allow-list (applies to every provider). Leave both blank to
# allow anyone who authenticates.
# AUTH_ALLOWED_DOMAINS=getboxie.com,packledger.co
# AUTH_ALLOWED_EMAILS=jon@getboxie.com

# ── Provider: Google OAuth ────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  <origin>/api/auth/google/callback
AUTH_GOOGLE_ENABLED=1
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# Optional — restrict to a Google Workspace domain.
# AUTH_GOOGLE_HD=getboxie.com

# ── Provider: Username / password ─────────────────────────────────────────────
# MVP stores users as "user:pass" pairs (comma-separated). Plaintext for now —
# hashing (bcrypt/argon2) is on the TODO list. Disable by leaving this off.
# AUTH_PASSWORD_ENABLED=1
# AUTH_USERS=jon@getboxie.com:change-me,ops:another-pass
