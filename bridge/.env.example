# talaria-bridge configuration (see src/config.ts). Copy to .env for local runs;
# in the docker stack these are set by stack/docker-compose.yml.

# Port the bridge listens on. hermes-workspace's HERMES_DASHBOARD_URL points here.
TALARIA_PORT=9119

# The REAL Hermes dashboard to reverse-proxy to. In the PackLedger fleet this is
# the kanban-dashboard service (command: dashboard --port 9119).
TALARIA_DASHBOARD_UPSTREAM=http://kanban-dashboard:9119

# mission-control base URL (the fleet brain). Leave EMPTY to run as a pure
# transparent proxy with no interception (M1 mode).
MISSION_CONTROL_URL=

# mission-control API key (Bearer). Prefer the _FILE form (docker secret).
# MISSION_CONTROL_API_KEY_FILE=/run/secrets/talaria_mc_key
MISSION_CONTROL_API_KEY=
