# Talaria stack env. Copy to .env and fill. Values feed talaria/stack/docker-compose.yml.

# ── mission-control (the fleet brain) ────────────────────────────────────────
# API key shared by the bridge + agents' Talaria plugin to auth to mission-control.
# Generate: openssl rand -hex 32
MISSION_CONTROL_API_KEY=change-me
# Internal URL the bridge uses to reach mission-control (default matches the service name).
MISSION_CONTROL_URL=http://mission-control:3000
# TODO(M5): pin real images (or switch to build: contexts once source is vendored).
MISSION_CONTROL_IMAGE=ghcr.io/builderz-labs/mission-control:latest
HERMES_WORKSPACE_IMAGE=ghcr.io/outsourc-e/hermes-workspace:latest

# ── the seam ─────────────────────────────────────────────────────────────────
# The REAL Hermes dashboard the bridge proxies (live fleet's kanban-dashboard).
TALARIA_DASHBOARD_UPSTREAM=http://kanban-dashboard:9119
# hermes-workspace points its dashboard mission API at the bridge (THE linchpin).
HERMES_DASHBOARD_URL=http://talaria-bridge:9119
# Workspace chat/streaming + gateway target — a REAL agent gateway, never the bridge.
# TODO(M0/M2): choose the gateway (single agent vs identity-proxy router).
HERMES_API_URL=http://agent-developer:8642
