# Talaria stack env. Copy to .env and fill. Values feed talaria/stack/docker-compose.yml.

# ── mission-control (the fleet brain) ────────────────────────────────────────
# API key shared by the bridge + agents' Talaria plugin to auth to mission-control.
# Generate: openssl rand -hex 32
MISSION_CONTROL_API_KEY=change-me
# Internal URL the bridge uses to reach mission-control (default matches the service name).
MISSION_CONTROL_URL=http://mission-control:3000
# mission-control has NO published image — build it locally (see stack/docker-compose.yml
# + stack/README.md). This is the local build tag. hermes-workspace IS published on ghcr.
MISSION_CONTROL_IMAGE=mission-control:latest
HERMES_WORKSPACE_IMAGE=ghcr.io/outsourc-e/hermes-workspace:latest

# ── the seam ─────────────────────────────────────────────────────────────────
# The REAL Hermes dashboard the bridge proxies (live fleet's kanban-dashboard).
TALARIA_DASHBOARD_UPSTREAM=http://kanban-dashboard:9119
# hermes-workspace points BOTH planes at Talaria:
#   dashboard plane (:9119) → conductor + kanban board from mission-control
#   gateway plane   (:8642) → the fleet multiplexer (model switcher = agent switcher)
HERMES_DASHBOARD_URL=http://talaria-bridge:9119
HERMES_API_URL=http://talaria-bridge:8642

# ── hermes-workspace auth ────────────────────────────────────────────────────
# Ignored by the gateway plane (it injects each agent's own key from the fleet manifest).
HERMES_API_TOKEN=
# Workspace session password — REQUIRED by hermes-workspace for non-loopback binds.
HERMES_PASSWORD=change-me
# Behind the Cloudflare/HTTPS tunnel: keep these true.
COOKIE_SECURE=true
TRUST_PROXY=true

# ── Talaria UI (Phase 2 — our own front end) ─────────────────────────────────
# Postgres password for the talaria-postgres service (durable per-user chat).
# Generate: openssl rand -hex 24
TALARIA_DB_PASSWORD=change-me
# Gateway plane the UI's BFF proxies to (defaults to the bridge's :8642).
TALARIA_GATEWAY_URL=http://talaria-bridge:8642
# External origin (for OAuth redirect URIs), e.g. https://talaria.packledger.co
AUTH_PUBLIC_URL=
# Admins (comma-separated emails). Everyone else who signs in is a member.
AUTH_ADMIN_EMAILS=jon@packledger.co
# Who may sign in at all (leave blank to allow anyone who authenticates).
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_EMAILS=
# Provider: Google OAuth (redirect URI: <AUTH_PUBLIC_URL>/api/auth/google/callback)
AUTH_GOOGLE_ENABLED=0
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_HD=
# Provider: username/password ("user:pass,user2:pass2" — hash for real deployments)
AUTH_PASSWORD_ENABLED=0
AUTH_USERS=
